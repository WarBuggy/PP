{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Clean Launcher Dev",
            "type": "shell",
            "command": "dotnet clean ../AxiomPlayground/src/Launcher -c Dev",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Clean Launcher Release",
            "type": "shell",
            "command": "dotnet clean ../AxiomPlayground/src/Launcher -c Release",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Clean Launcher Dev Lib",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "if (Test-Path \"${workspaceFolder}/../AxiomPlayground/lib/Dev\") { Remove-Item -Recurse -Force \"${workspaceFolder}/../AxiomPlayground/lib/Dev\" }"
            ]
        },
        {
            "label": "Clean Launcher Release Lib",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "if (Test-Path \"${workspaceFolder}/../AxiomPlayground/lib/Release\") { Remove-Item -Recurse -Force \"${workspaceFolder}/../AxiomPlayground/lib/Release\" }"
            ]
        },
        {
            "label": "Clean Dev",
            "dependsOn": [
                "Clean Launcher Dev",
                "Clean Launcher Dev Lib"
            ]
        },
        {
            "label": "Clean Release",
            "dependsOn": [
                "Clean Launcher Release",
                "Clean Launcher Release Lib"
            ]
        },
        {
            "label": "Build Dev",
            "type": "shell",
            "command": "dotnet build PP.sln -c Dev",
            "dependsOn": [
                "Clean Dev"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "dotnet build PP.sln -c Release",
            "dependsOn": [
                "Clean Release"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "Build Launcher Dev",
            "type": "shell",
            "command": "dotnet build ../AxiomPlayground/src/Launcher -c Dev",
            "dependsOn": [
                "Clean Launcher Dev"
            ],
            "problemMatcher": "$msCompile"
        },
    ]
}