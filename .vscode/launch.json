{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (Console) Dev",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Dev",
      "program": "${workspaceFolder}/bin/Dev/PP.dll",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "-debug"
      ]
    },
    {
      "name": ".NET Core Launch (Console) Release",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Release",
      "program": "${workspaceFolder}/bin/Release/PP.dll",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "-debug"
      ]
    },
    {
      "name": ".NET Core Launch (Console) Launcher Dev",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "Build Launcher Dev",
      "program": "${workspaceFolder}/bin/Dev/Launcher.dll",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "args": [
        "-debug"
      ]
    },
  ]
}